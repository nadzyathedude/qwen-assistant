# Inference mode: "local" or "remote"
MODE=local

# Path to llama.cpp main binary
LLAMA_CPP_PATH=./llama.cpp/build/bin/llama-cli

# Path to GGUF model file
MODEL_PATH=./models/qwen.gguf

# Generation parameters
MAX_TOKENS=512
TEMPERATURE=0.7
TOP_P=0.9
REPEAT_PENALTY=1.1

# Number of GPU layers to offload (-1 = all)
GPU_LAYERS=0

# Context window size
CTX_SIZE=4096

# Threads for CPU inference
THREADS=4

# Remote server settings (used in remote mode or by server)
REMOTE_URL=http://127.0.0.1:8000
API_TOKEN=changeme
HOST=0.0.0.0
PORT=8000
TIMEOUT=120

# System prompt
SYSTEM_PROMPT=You are a helpful assistant. Answer concisely and accurately.

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
