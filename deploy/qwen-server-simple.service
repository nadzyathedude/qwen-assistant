[Unit]
Description=Qwen Inference Server
After=network.target

[Service]
Type=simple
User=qwen
Group=qwen
WorkingDirectory=/opt/qwen-assistant
EnvironmentFile=/opt/qwen-assistant/.env
ExecStart=/opt/qwen-assistant/venv/bin/python -m server.app
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
